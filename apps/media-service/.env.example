NODE_ENV=development
# Local : 3004 (le front Next.js occupe 3002). Docker : 3002 dans le conteneur.
PORT=3004

# Local : localhost — Docker : noms de service compose
REDIS_URL=redis://localhost:6380
GATEWAY_URL=http://localhost:3010
MEDIA_SERVICE_INTERNAL_URL=http://localhost:3004

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sonoria-audio
S3_FORCE_PATH_STYLE=true

# Job queue (BullMQ)
JOB_QUEUE_NAME=media-processing
