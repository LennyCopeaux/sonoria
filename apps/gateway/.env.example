NODE_ENV=development
# 3010 si le port 3000 est déjà pris en local
PORT=3010

# Redis (registry + rate-limit + token blacklist)
# Docker : redis://redis:6379 — Local : redis://localhost:6380
REDIS_URL=redis://localhost:6380

# JWT — RS256 public key (PEM in base64, single line)
JWT_PUBLIC_KEY=

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS (front)
CORS_ORIGIN=http://localhost:3002
