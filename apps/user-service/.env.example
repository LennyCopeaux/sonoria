NODE_ENV=development
PORT=3001

# Docker : postgres / redis — Local : localhost
DATABASE_URL=postgresql://sonoria:sonoria@localhost:5432/sonoria
# Port 6380 si un autre Redis occupe déjà 6379 en local
REDIS_URL=redis://localhost:6380

# Generate with: bash scripts/generate-keys.sh
JWT_PRIVATE_KEY=<base64-encoded-rsa-2048-private-key>
JWT_PUBLIC_KEY=<base64-encoded-rsa-2048-public-key>

# Docker : http://gateway:3010 — Local : http://localhost:3010 (évite conflit avec un autre projet sur 3000)
GATEWAY_URL=http://localhost:3010
USER_SERVICE_INTERNAL_URL=http://localhost:3001

# Token partagé avec job-runner pour PATCH /tracks/:id/internal
INTERNAL_API_TOKEN=dev-internal-secret

# Docker : http://media-service:3002 — Local : http://localhost:3004 (le front occupe 3002)
MEDIA_SERVICE_URL=http://localhost:3004

# Queue BullMQ partagée avec job-runner (jobs stats:aggregate / reco:refresh)
JOB_QUEUE_NAME=media-processing
