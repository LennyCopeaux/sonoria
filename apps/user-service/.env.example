NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://sonoria:sonoria@postgres:5432/sonoria
REDIS_URL=redis://redis:6379

# Generate with: bash scripts/generate-keys.sh
JWT_PRIVATE_KEY=<base64-encoded-rsa-2048-private-key>
JWT_PUBLIC_KEY=<base64-encoded-rsa-2048-public-key>

GATEWAY_URL=http://gateway:3000

# Token partagé avec job-runner pour PATCH /tracks/:id/internal
INTERNAL_API_TOKEN=dev-internal-secret

MEDIA_SERVICE_URL=http://media-service:3002
